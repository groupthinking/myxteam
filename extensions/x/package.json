{
  "name": "@openclaw/x",
  "version": "0.1.0",
  "description": "OpenClaw X (Twitter) channel plugin for mention-driven agent interactions",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "x",
      "label": "X (Twitter)",
      "selectionLabel": "X (Twitter) — Mention-driven agents",
      "docsPath": "/channels/x",
      "docsLabel": "x",
      "blurb": "AI agents on X, activated by @mentions. Supports multi-account via OAuth 2.0.",
      "order": 56,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@openclaw/x",
      "localPath": "extensions/x",
      "defaultChoice": "npm"
    }
  }
}
